// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  EMPLOYEE
}

enum Module {
  CARNES_PREPARADAS
  CARNES_AHUMADAS
  CARNE_CRUDA
  VERDURAS
  BEBIDAS_BODEGA
  BEBIDAS_SERVICIO
  SALSAS
  COCINA
  SERVICIO
  BODEGA
  DESECHABLES
  GUARNICIONES
  VERDURAS_RESTAURANTE
  HARINAS_ACEITE_RESTAURANTE
  HARINAS_ACEITE_BODEGA
  LACTEOS_RESTAURANTE
  LACTEOS_BODEGA
  CONDIMENTOS_RESTAURANTE
  DESECHABLES_BOLSAS_RESTAURANTE
  DESECHABLES_BODEGA
  SALSAS_ADEREZOS_RESTAURANTE
  LIMPIEZA_RESTAURANTE
  SALSAS_ADEREZOS_BODEGA
  CONDIMENTOS_BODEGA
  MATERIA_PRIMA_SALSA
  LIMPIEZA_BODEGA
}

enum StockStatus {
  OK
  BAJO
  CRITICO
}

model User {
  id        String        @id @default(cuid())
  name      String
  pin       String
  role      Role          @default(EMPLOYEE)
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  records   DailyRecord[]
}

model Product {
  id        String        @id @default(cuid())
  name      String
  category  String
  module    Module
  unit      String        @default("unidad")
  minStock  Float         @default(0)
  maxStock  Float?
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  records   DailyRecord[]
}

model DailyRecord {
  id            String      @id @default(cuid())
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  date          DateTime    @db.Date

  // Stock simple (cocina, bodega, servicio, salsas)
  currentStock  Float?

  // Seguimiento de peso (carnes preparadas, carne cruda, verduras)
  initialWeight Float?
  restock       Float?
  waste1        Float?
  waste2        Float?
  finalWeight   Float?

  // Carnes ahumadas
  units         Int?
  weightLb      Float?

  // Bebidas servicio
  initialStock  Float?
  finalStock    Float?
  consumption   Float?

  status        StockStatus @default(OK)
  notes         String?
  userId        String?
  user          User?       @relation(fields: [userId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([productId, date])
}

model Alert {
  id          String      @id @default(cuid())
  productId   String
  productName String
  module      Module
  status      StockStatus
  message     String
  read        Boolean     @default(false)
  createdAt   DateTime    @default(now())
}

model DayClose {
  id           String   @id @default(cuid())
  date         DateTime @unique @db.Date
  closedAt     DateTime @default(now())
  closedByName String
}
